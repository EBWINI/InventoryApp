<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:InventoryApp"
             x:Class="InventoryApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="TextPrimary">#1e293b</Color>
            <Color x:Key="TextSecondary">#475569</Color>
            <Color x:Key="TextMuted">#94a3b8</Color>
            <Color x:Key="BgPage">#f0f4f8</Color>
            <Color x:Key="BgCard">White</Color>
            <Color x:Key="BgCardBorder">#e2e8f0</Color>
            <Color x:Key="PrimaryColor">#4f46e5</Color>
            <Color x:Key="SuccessColor">#16a34a</Color>
            <Color x:Key="DangerColor">#dc2626</Color>
            <Color x:Key="WarningColor">#f59e0b</Color>

            <!-- inline converter for status color -->
            <local:StatusColorConverter x:Key="StatusColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
